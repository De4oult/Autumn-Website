{
    "hosting": {
        "public": ".output/public",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "trailingSlash": true,
        "redirects": [
            {
                "source": "/sitemap_index.xml",
                "destination": "/sitemap.xml",
                "type": 301
            },
            {
                "source": "/en-US.xml",
                "destination": "/sitemap.xml",
                "type": 301
            },
            {
                "source": "/ru-RU.xml",
                "destination": "/sitemap.xml",
                "type": 301
            },
            {
                "source": "/__sitemap__/:file",
                "destination": "/sitemap.xml",
                "type": 301
            },
            {
                "source": "/:locale/__sitemap__/:file",
                "destination": "/sitemap.xml",
                "type": 301
            }
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/200.html"
            }
        ]
    }
}
